# domínio principal. crie registros A apontando para o ip do vps:
#   your-lab.duckdns.org         -> ip-do-vps
#   firefox.your-lab.duckdns.org -> ip-do-vps  (auto via wildcard do duckdns)
#   chrome.your-lab.duckdns.org  -> ip-do-vps  (auto via wildcard do duckdns)
DOMAIN=your-lab.duckdns.org

# ip público do vps (necessário para o NEKO_WEBRTC_NAT1TO1).
# descubra com: curl -4 ifconfig.io
PUBLIC_IP=203.0.113.10

# e-mail para let's encrypt (avisos de expiração de certificado).
LETSENCRYPT_EMAIL=voce@exemplo.com

# senhas do neko (provider multiuser). use senhas fortes — gere com:
#   openssl rand -base64 24
NEKO_ADMIN_PASSWORD=trocar-por-senha-forte-admin
NEKO_USER_PASSWORD=trocar-por-senha-forte-user
